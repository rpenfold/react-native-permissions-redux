{
  "name": "react-native-permissions-redux",
  "version": "0.0.2",
  "description": "Redux slice for react-native-permissions with automatic foreground sync",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepare": "husky"
  },
  "keywords": [
    "react-native",
    "permissions",
    "redux",
    "redux-toolkit",
    "react-native-permissions"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.70",
    "react-native-permissions": ">=4",
    "react-redux": ">=9",
    "@reduxjs/toolkit": ">=2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@reduxjs/toolkit": "^2.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.0.0",
    "react": "^18.2.0",
    "react-native": "^0.73.0",
    "react-native-permissions": "^4.0.0",
    "react-redux": "^9.0.0",
    "react-test-renderer": "^18.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFiles": ["./jest.setup.ts"],
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "tsx", "js", "json"]
  },
  "lint-staged": {
    "*.{ts,tsx,json,md}": ["biome check --write --no-errors-on-unmatched"]
  }
}
